# Variables de entorno para Script App
# Copia este archivo como .env.local y llena los valores

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_PRIVY_APP_ID=your-privy-app-id
EXPO_PUBLIC_PRIVY_CLIENT_ID=your-privy-client-id   # Settings → Clients → Create client (Native, bundle: host.exp.exponent)
